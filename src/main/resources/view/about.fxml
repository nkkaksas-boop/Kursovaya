<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="nntc.svg52.fxapp.controller.AboutController">
    <padding>
        <Insets bottom="30" left="30" right="30" top="30" />
    </padding>

    <Label fx:id="appNameLabel" style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Электронное меню ресторана" />

    <Label fx:id="versionLabel" text="Версия: 1.0.0" />

    <Separator prefWidth="200" />

    <Label fx:id="descriptionLabel" text="Курсовой проект по МДК 11.01" />
    <Label fx:id="authorLabel" text="Автор: Хозяинов Андрей Сергеевич" />
    <Label fx:id="groupLabel" text="Группа: ЗИСиП-23-1" />
    <Label fx:id="yearLabel" text="2025" />

    <Separator prefWidth="200" />

    <Label text="Нижегородский радиотехнический колледж" wrapText="true" />

    <Button fx:id="closeButton" onAction="#handleClose" prefWidth="100" text="OK">
        <font>
            <Font size="14" />
        </font>
    </Button>
</VBox>