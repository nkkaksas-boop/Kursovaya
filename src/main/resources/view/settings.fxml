<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="nntc.svg52.fxapp.controller.SettingsController">
    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>

    <Label style="-fx-font-size: 16px; -fx-font-weight: bold;" text="Настройки подключения к БД" />

    <GridPane hgap="10" vgap="10">
        <columnConstraints>
            <ColumnConstraints halignment="RIGHT" minWidth="100" />
            <ColumnConstraints hgrow="ALWAYS" minWidth="200" />
        </columnConstraints>

        <Label text="Хост:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <TextField fx:id="hostField" GridPane.columnIndex="1" GridPane.rowIndex="0" promptText="localhost" />

        <Label text="Порт:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <TextField fx:id="portField" GridPane.columnIndex="1" GridPane.rowIndex="1" promptText="5432" />

        <Label text="База данных:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
        <TextField fx:id="databaseField" GridPane.columnIndex="1" GridPane.rowIndex="2" promptText="restaurant_menu" />

        <Label text="Схема:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
        <TextField fx:id="schemaField" GridPane.columnIndex="1" GridPane.rowIndex="3" promptText="restaurant_schema" />

        <Label text="Пользователь:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
        <TextField fx:id="usernameField" GridPane.columnIndex="1" GridPane.rowIndex="4" promptText="postgres" />

        <Label text="Пароль:" GridPane.columnIndex="0" GridPane.rowIndex="5" />
        <PasswordField fx:id="passwordField" GridPane.columnIndex="1" GridPane.rowIndex="5" promptText="postgres" />
    </GridPane>

    <HBox alignment="CENTER" spacing="10">
        <Button fx:id="testButton" onAction="#handleTestConnection" text="Проверить подключение" />
        <Button fx:id="saveButton" onAction="#handleSave" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" text="Сохранить" />
        <Button fx:id="cancelButton" onAction="#handleCancel" text="Отмена" />
    </HBox>

    <Label fx:id="statusLabel" textFill="green" wrapText="true" />
</VBox>