<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="nntc.svg52.fxapp.controller.SettingsController">
    <padding>
        <Insets bottom="20" left="20" right="20" top="20"/>
    </padding>
    <Label style="-fx-font-size: 16px; -fx-font-weight: bold;" text="Настройки подключения к БД"/>
    <GridPane hgap="10" vgap="10">
        <columnConstraints>
            <ColumnConstraints halignment="RIGHT" minWidth="100"/>
            <ColumnConstraints hgrow="ALWAYS" minWidth="200"/>
        </columnConstraints>
        <Label text="Хост:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="hostTextField" promptText="localhost" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        <Label text="Порт:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="portTextField" promptText="5432" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        <Label text="База данных:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <TextField fx:id="databaseTextField" promptText="restaurant_menu" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
        <Label text="Схема:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <TextField fx:id="schemaTextField" promptText="public" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
        <Label text="Пользователь:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
        <TextField fx:id="usernameTextField" promptText="postgres" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
        <Label text="Пароль:" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
        <PasswordField fx:id="passwordTextField" promptText="postgres" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
    </GridPane>
    <HBox alignment="CENTER" spacing="10">
        <Button fx:id="testButton" onAction="#handleTestConnection" text="Проверить подключение"/>
        <Button fx:id="saveButton" onAction="#handleSave" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" text="Сохранить"/>
        <Button fx:id="cancelButton" onAction="#handleCancel" text="Отмена"/>
    </HBox>
    <Label fx:id="statusLabel" textFill="green" wrapText="true"/>
</VBox>